# Client env for the live-H2H pilot mode. Copy to .env.local (gitignored) and fill
# in. Both are browser-safe: the anon key grants nothing on its own — every table
# is RLS-guarded (supabase/migrations). Without these, the app still builds and the
# static vs-AI demo works; only "Live" mode shows a "not configured" notice.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
