# Drip pilot worker — copy to server/.env and fill in. NEVER commit the real .env.
# The service-role key bypasses Postgres RLS; treat it like a root password.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Pilot scope
PILOT_SEASON=2026
# Comma-separated Sleeper league ids to sync (optional; the sync CLI also takes ids as args)
PILOT_LEAGUE_IDS=

# Poll cadences (ms)
PLAYS_POLL_MS=25000          # live PBP during game windows
SCOREBOARD_POLL_MS=60000     # game state / kickoff detection
INJURY_POLL_MS_DAILY=86400000
INJURY_POLL_MS_GAMEDAY=3600000
