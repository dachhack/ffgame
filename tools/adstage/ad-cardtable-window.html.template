<!doctype html>
<html>
<head>
<meta charset="utf-8">
<style>
@font-face { font-family: 'Space Grotesk'; src: url(data:font/woff2;base64,__SG__) format('woff2'); font-weight: 300 800; }
@font-face { font-family: 'Lilita One'; src: url(data:font/woff2;base64,__LO__) format('woff2'); }
:root {
  --bg: #08141A; --surface: #0E1E26; --bd: #1E3540;
  --you: #2EE6C0; --opp: #FF5A6E; --warn: #F4C95D; --nuke: #FF4F62; --ice: #7FD4FF;
  --text: #EAF4F2; --dim: #8FA8A6; --faint: #5C7472;
  --cream: #F2EAD3; --cream2: #E5DBBE; --ink: #2A2312; --gold: #FFD86B;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { background: #000; }
#stage { position: relative; width: 1080px; height: 1350px; overflow: hidden;
  background: radial-gradient(120% 90% at 50% 8%, #0D2530 0%, var(--bg) 55%, #050D11 100%);
  font-family: 'Space Grotesk', system-ui, sans-serif; color: var(--text); }
#stage::after { content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(85% 75% at 50% 45%, transparent 60%, rgba(0,0,0,.42) 100%); }
.mono { font-family: ui-monospace, 'SF Mono', Menlo, monospace; }
.topchip { position: absolute; top: 56px; left: 0; right: 0; text-align: center; font-size: 24px; font-weight: 700; letter-spacing: .28em; color: var(--faint); z-index: 5; }
.headline { position: absolute; top: 108px; left: 0; right: 0; text-align: center; font-size: 56px; font-weight: 700; letter-spacing: -.01em; z-index: 5; transition: opacity .4s; }
.footline { position: absolute; bottom: 148px; left: 60px; right: 60px; text-align: center; font-size: 36px; font-weight: 700; color: var(--dim); z-index: 5; transition: opacity .4s; line-height: 1.35; }
.footline b { color: var(--text); }

/* table */
#table { position: absolute; top: 218px; left: 0; right: 0; display: flex; flex-direction: column; align-items: center; gap: 20px; }
.vsdiv { display: flex; align-items: center; gap: 20px; width: 780px; margin: 14px 0; }
.vsdiv .ln { flex: 1; height: 2px; background: linear-gradient(90deg, transparent, var(--bd) 30%, var(--bd) 70%, transparent); }
.vsdiv .vs { font-size: 30px; font-weight: 800; letter-spacing: .18em; color: var(--dim); border: 2px solid var(--bd); border-radius: 999px; padding: 10px 26px; background: var(--surface); font-family: ui-monospace, Menlo, monospace; }
.rowlab { font-size: 22px; font-weight: 800; letter-spacing: .3em; color: var(--faint); }
.crow { display: flex; gap: 28px; }

/* mini cards */
.mini { width: 250px; height: 356px; perspective: 1200px; position: relative; }
.mini .card { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; transition: transform .7s cubic-bezier(.3,1.3,.45,1); }
.mini.flipped .card { transform: rotateY(180deg); }
.cface { position: absolute; inset: 0; backface-visibility: hidden; border-radius: 16px; border: 3px solid #000; box-shadow: 0 14px 34px rgba(0,0,0,.55), 0 3px 0 #000; }
.cback { background: radial-gradient(circle at 50% 42%, #7E2430 0%, #571C26 62%, #40151E 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; }
.cback .gem { font-size: 56px; color: #E9B959; text-shadow: 0 4px 0 #000; }
.cback .seal { font-size: 13px; letter-spacing: .3em; color: #D9A0A6; border: 2px solid rgba(233,185,89,.45); padding: 7px 12px; border-radius: 6px; background: rgba(0,0,0,.35); }
.cback::before { content: ''; position: absolute; inset: 11px; border: 2px solid rgba(233,185,89,.35); border-radius: 10px; }
.cfront { transform: rotateY(180deg);
  background: radial-gradient(circle at 50% 12%, #FFFDF4 0%, var(--cream) 46%, var(--cream2) 100%);
  color: var(--ink); display: flex; flex-direction: column; align-items: center; padding: 14px 12px; }
.mini.you .card { transform: rotateY(180deg); } /* your cards start face-up */
.pospill { align-self: flex-start; font-size: 15px; font-weight: 800; letter-spacing: .06em; padding: 4px 9px; border-radius: 7px; border: 3px solid; }
.pos-rb { color: #1D7A4F; border-color: #1D7A4F; } .pos-wr { color: #6D4FD1; border-color: #6D4FD1; }
.pos-te { color: #C05621; border-color: #C05621; }
.cname { font-family: 'Lilita One', sans-serif; font-size: 26px; line-height: 1.08; letter-spacing: .02em; text-align: center; margin-top: 24px; text-transform: uppercase; }
.cteam { font-size: 15px; font-weight: 700; letter-spacing: .18em; color: #6E6650; margin-top: 7px; font-family: ui-monospace, Menlo, monospace; }
.cmet { margin-top: auto; font-size: 14.5px; font-weight: 800; letter-spacing: .02em; color: var(--gold); background: linear-gradient(#3A2E15, #241C10); border: 2px solid #000; border-radius: 7px; padding: 6px 11px; box-shadow: 0 3px 0 #000, inset 0 0 9px rgba(255,216,107,.28); text-shadow: 0 1px 0 #000; font-family: ui-monospace, Menlo, monospace; }
.cmet.nukey { color: #FFB3BC; background: linear-gradient(#4A1218, #2A0C10); box-shadow: 0 3px 0 #000, inset 0 0 11px rgba(255,79,98,.4); }
.cmet.nukey.blink { animation: metblink .8s ease 2; }
@keyframes metblink { 0%,100% { box-shadow: 0 3px 0 #000, inset 0 0 11px rgba(255,79,98,.4) } 50% { box-shadow: 0 3px 0 #000, 0 0 26px rgba(255,79,98,.95), inset 0 0 11px rgba(255,79,98,.6) } }

/* big on-card running score */
.score { margin-top: auto; font-size: 78px; font-weight: 700; letter-spacing: -.03em; line-height: 1; font-family: 'Space Grotesk', sans-serif; color: #B7273B; opacity: .28; transition: opacity .5s; }
.mini.you .score { color: #0B7D66; }
#table.golive .score { opacity: 1; }
.sclab { font-size: 13px; font-weight: 800; letter-spacing: .3em; color: #6E6650; margin-top: 6px; font-family: ui-monospace, Menlo, monospace; opacity: .7; }
/* bank chip on card (retired) */
.bank { position: absolute; left: 50%; bottom: -24px; transform: translateX(-50%); z-index: 3;
  font-size: 24px; font-weight: 800; font-family: ui-monospace, Menlo, monospace; color: var(--text);
  background: #0A1A21; border: 2px solid var(--bd); border-radius: 10px; padding: 6px 16px; box-shadow: 0 4px 14px rgba(0,0,0,.5); opacity: 0; transition: opacity .4s; }
.bank.on { opacity: 1; }
.crow.you .bank { border-color: color-mix(in srgb, var(--you) 55%, var(--bd)); color: var(--you); }
.crow.them .bank { border-color: color-mix(in srgb, var(--opp) 55%, var(--bd)); color: var(--opp); }

/* floaters */
.floater { position: absolute; left: 50%; top: 30%; transform: translateX(-50%); font-size: 26px; font-weight: 800; font-family: ui-monospace, Menlo, monospace; color: var(--you); z-index: 4; animation: floatup 1.2s ease-out forwards; text-shadow: 0 2px 8px rgba(0,0,0,.7); }
.crow.them .floater { color: var(--opp); }
@keyframes floatup { 0% { opacity: 0; transform: translate(-50%, 6px) } 20% { opacity: 1 } 100% { opacity: 0; transform: translate(-50%, -52px) } }

/* scorch + frost overlays */
.scorch { position: absolute; inset: 0; border-radius: 16px; background: radial-gradient(circle at 50% 40%, rgba(120,10,20,.78), rgba(40,4,8,.9)); z-index: 2; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; opacity: 0; transition: opacity .5s; }
.scorch.on { opacity: 1; }
.scorch .sk { font-size: 74px; filter: drop-shadow(0 0 16px rgba(255,79,98,.8)); }
.scorch .t { font-size: 20px; font-weight: 800; letter-spacing: .26em; color: #FFB3BC; font-family: ui-monospace, Menlo, monospace; }
.frost { position: absolute; inset: 0; border-radius: 16px; background: linear-gradient(rgba(150,215,255,.28), rgba(60,120,170,.34)); border: 3px solid var(--ice); z-index: 2; display: flex; flex-direction: row; align-items: flex-start; justify-content: center; padding-top: 134px; gap: 9px; opacity: 0; transition: opacity .5s; box-shadow: inset 0 0 40px rgba(127,212,255,.55); }
.frost.on { opacity: 1; }
.frost .ic { font-size: 28px; line-height: 1; filter: drop-shadow(0 0 14px rgba(127,212,255,.9)); }
.frost .t { font-size: 15px; padding-top: 7px; text-align: center; font-weight: 800; letter-spacing: .26em; color: #DFF4FF; font-family: ui-monospace, Menlo, monospace; }

/* boom + flash + quake */
#stage.quake { animation: quake .55s ease; }
@keyframes quake { 0%,100% { transform: none } 15% { transform: translate(-14px,8px) rotate(-.5deg) } 35% { transform: translate(12px,-10px) rotate(.4deg) } 55% { transform: translate(-9px,-6px) } 75% { transform: translate(7px,9px) } }
#flashlayer { position: absolute; inset: 0; background: radial-gradient(circle at 50% 42%, rgba(255,110,120,.75), rgba(255,79,98,.18) 55%, transparent 75%); opacity: 0; pointer-events: none; z-index: 40; }
#flashlayer.go { animation: flashout 1s ease-out; }
#iceflash { position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(150,220,255,.65), rgba(127,212,255,.15) 55%, transparent 75%); opacity: 0; pointer-events: none; z-index: 40; }
#iceflash.go { animation: flashout 1.1s ease-out; }
@keyframes flashout { 0% { opacity: 1 } 100% { opacity: 0 } }
.boomcard { position: absolute; z-index: 41; text-align: center; opacity: 0; left: 50%; transform: translateX(-50%); }
.boomcard.go { animation: boomin 1s cubic-bezier(.2,1.7,.4,1) forwards; }
@keyframes boomin { 0% { opacity: 0; transform: translateX(-50%) scale(.2) } 40% { opacity: 1; transform: translateX(-50%) scale(1.3) } 65% { transform: translateX(-50%) scale(.95) } 100% { opacity: 1; transform: translateX(-50%) scale(1) } }
.boomcard .bx { font-size: 150px; line-height: 1; filter: drop-shadow(0 0 40px rgba(255,79,98,.9)); }
.playline { position: absolute; top: 176px; left: 0; right: 0; text-align: center; font-size: 32px; font-weight: 800; letter-spacing: .12em; color: var(--warn); opacity: 0; transition: opacity .3s; z-index: 42; font-family: ui-monospace, Menlo, monospace; }
.playline.on { opacity: 1; }

/* EMP power-up card */
#empcard { position: absolute; left: 50%; top: 46%; transform: translate(-50%,-50%) scale(0); z-index: 45;
  width: 400px; background: linear-gradient(#142832, #0C1B22); border: 3px solid var(--ice); border-radius: 18px; padding: 34px 30px; text-align: center;
  box-shadow: 0 0 60px rgba(127,212,255,.4), 0 24px 60px rgba(0,0,0,.65); }
#empcard.go { animation: empdeal .6s cubic-bezier(.2,1.6,.4,1) forwards; }
@keyframes empdeal { 0% { opacity: 0; transform: translate(-50%,-30%) scale(.4) rotate(6deg) } 100% { opacity: 1; transform: translate(-50%,-50%) scale(1) rotate(0) } }
#empcard.gone { animation: empgone .45s ease forwards; }
@keyframes empgone { to { opacity: 0; transform: translate(-50%,-80%) scale(.6) } }
#empcard .icon { font-size: 84px; }
#empcard .nm { font-size: 36px; font-weight: 800; letter-spacing: .08em; color: var(--ice); margin-top: 12px; font-family: ui-monospace, Menlo, monospace; }
#empcard .bl { font-size: 22px; color: var(--dim); margin-top: 10px; line-height: 1.4; }
#empcard .use { display: inline-block; margin-top: 20px; font-size: 22px; font-weight: 800; letter-spacing: .12em; color: #06222E; background: var(--ice); border-radius: 10px; padding: 12px 26px; font-family: ui-monospace, Menlo, monospace; }

/* final + end scenes */
.scene { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity .45s ease; z-index: 50; background: radial-gradient(120% 90% at 50% 10%, #0D2530 0%, var(--bg) 60%, #050D11 100%); }
.scene.on { opacity: 1; }
.fscore { display: flex; align-items: baseline; gap: 40px; }
.fname { font-size: 40px; font-weight: 700; color: var(--dim); letter-spacing: .04em; }
.fnum { font-size: 170px; font-weight: 700; letter-spacing: -.03em; line-height: 1; }
.won { margin-top: 56px; font-size: 28px; font-weight: 800; letter-spacing: .28em; color: var(--you); border: 2px solid var(--you); padding: 13px 30px; border-radius: 999px; font-family: ui-monospace, Menlo, monospace; }
.again { font-size: 40px; font-weight: 800; letter-spacing: .1em; color: var(--warn); margin-bottom: 54px; font-family: ui-monospace, Menlo, monospace; }
.mark { font-size: 58px; font-weight: 800; letter-spacing: .16em; display: flex; align-items: center; gap: 20px; }
.mark .g { color: #E9B959; }
.tag2 { margin-top: 40px; font-size: 56px; font-weight: 700; text-align: center; line-height: 1.15; }
.facts { margin-top: 30px; font-size: 26px; letter-spacing: .2em; color: var(--dim); font-weight: 700; font-family: ui-monospace, Menlo, monospace; }
.cta { margin-top: 74px; font-size: 32px; font-weight: 800; color: #05221C; background: var(--you); padding: 24px 50px; border-radius: 16px; box-shadow: 0 0 54px color-mix(in srgb, var(--you) 45%, transparent); }
.url { margin-top: 28px; font-size: 28px; letter-spacing: .22em; color: var(--dim); font-weight: 700; font-family: ui-monospace, Menlo, monospace; }
</style>
</head>
<body>
<div id="stage">
  <div class="topchip mono">SUNDAY · 1:00 PM · THREE SLOTS</div>
  <div class="headline" id="headline">Six cards on the table.</div>

  <div id="table">
    <div class="rowlab mono" id="lab1">THEIR ROW — SEALED</div>
    <div class="crow them" id="rowThem">
      <div class="mini" id="t0"><div class="card">
        <div class="cface cback"><div class="gem">◆</div><div class="seal mono">SEALED</div></div>
        <div class="cface cfront"><div class="pospill pos-rb mono">RB</div><div class="cname">J. Gibbs</div><div class="cteam">RB · DET</div><div class="score" id="bt0">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet">Rush Yards · DRIP</div></div>
      </div><div class="frost" id="ft0"><div class="ic">❄️</div><div class="t">FROZEN &middot; 10 MIN</div></div></div>
      <div class="mini" id="t1"><div class="card">
        <div class="cface cback"><div class="gem">◆</div><div class="seal mono">SEALED</div></div>
        <div class="cface cfront"><div class="pospill pos-wr mono">WR</div><div class="cname">P. Nacua</div><div class="cteam">WR · LA</div><div class="score" id="bt1">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet">Receiving Yds · DRIP</div></div>
      </div><div class="frost" id="ft1"><div class="ic">❄️</div><div class="t">FROZEN &middot; 10 MIN</div></div></div>
      <div class="mini" id="t2"><div class="card">
        <div class="cface cback"><div class="gem">◆</div><div class="seal mono">SEALED</div></div>
        <div class="cface cfront"><div class="pospill pos-te mono">TE</div><div class="cname">H. Fannin</div><div class="cteam">TE · CLE</div><div class="score" id="bt2">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet nukey" id="nukemet">TDs · 12-PT NUKE</div></div>
      </div><div class="frost" id="ft2"><div class="ic">❄️</div><div class="t">FROZEN &middot; 10 MIN</div></div></div>
    </div>
    <div class="vsdiv"><div class="ln"></div><div class="vs">VS</div><div class="ln"></div></div>
    <div class="crow you" id="rowYou">
      <div class="mini you" id="y0"><div class="card">
        <div class="cface cback"></div>
        <div class="cface cfront"><div class="pospill pos-rb mono">RB</div><div class="cname">C. McCaffrey</div><div class="cteam">RB · SF</div><div class="score" id="by0">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet">Rush Yards · DRIP</div></div>
      </div></div>
      <div class="mini you" id="y1"><div class="card">
        <div class="cface cback"></div>
        <div class="cface cfront"><div class="pospill pos-wr mono">WR</div><div class="cname">D. Smith</div><div class="cteam">WR · PHI</div><div class="score" id="by1">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet">Receiving Yds · DRIP</div></div>
      </div></div>
      <div class="mini you" id="y2"><div class="card">
        <div class="cface cback"></div>
        <div class="cface cfront"><div class="pospill pos-te mono">TE</div><div class="cname">G. Kittle</div><div class="cteam">TE · SF</div><div class="score" id="by2">0.0</div><div class="sclab">BANK · LIVE</div><div class="cmet">Receptions · ERASE</div></div>
      </div><div class="scorch" id="sy2"><div class="sk">☠</div><div class="t">NUKED · 0.0</div></div></div>
    </div>
    <div class="rowlab mono">YOUR ROW</div>
  </div>

  <div class="footline" id="footline">Yours are set. <b>Theirs stay sealed until kickoff.</b></div>

  <div class="playline mono" id="playline">31:12 — FANNIN · 4-YD CATCH · TOUCHDOWN</div>
  <div class="boomcard" id="boom" style="top: 620px"><div class="bx">💥</div></div>
  <div id="empcard"><div class="icon">❄️</div><div class="nm">EMP</div><div class="bl">Freeze their drip clock<br>for 10 min mid-game.</div><div class="use">⚡ USE NOW</div></div>
  <div id="flashlayer"></div><div id="iceflash"></div>

  <div class="scene" id="s6">
    <div class="again">WINDOW FINAL · SUN 1PM</div>
    <div class="fscore">
      <div style="text-align:center"><div class="fname">YOU</div><div class="fnum" style="color:var(--you)">33.4</div></div>
      <div class="fname" style="font-size:56px; color:var(--faint)">–</div>
      <div style="text-align:center"><div class="fname">THEM</div><div class="fnum" style="color:var(--dim)">32.8</div></div>
    </div>
    <div class="won">WON BY 0.6 · EMP SAVED IT</div>
  </div>
  <div class="scene" id="s7">
    <div class="mark"><span class="g">◈</span> DRIP FANTASY</div>
    <div class="tag2">Fantasy football<br>where you fight back.</div>
    <div class="facts">HIDDEN PICKS · LIVE SABOTAGE · YOUR LEAGUE</div>
    <div class="cta">Get a code for your league</div>
    <div class="url">DRIPFANTASY.COM</div>
  </div>
</div>

<script>
const $ = (id) => document.getElementById(id);
function count(el, from, to, ms, dp = 1) {
  const t0 = performance.now();
  (function f(t) {
    const k = Math.min(1, (t - t0) / ms);
    el.textContent = (from + (to - from) * (k < .5 ? 2*k*k : 1 - Math.pow(-2*k + 2, 2) / 2)).toFixed(dp);
    if (k < 1) requestAnimationFrame(f);
  })(t0);
}
function floater(cardId, txt) {
  const d = document.createElement('div');
  d.className = 'floater'; d.textContent = txt;
  $(cardId).appendChild(d);
  setTimeout(() => d.remove(), 1300);
}
window.__START = () => {
  const at = (ms, fn) => setTimeout(fn, ms);
  // S1: table set 0–3.8
  // S2: reveal 3.8–8.2
  at(3800, () => {
    $('headline').textContent = '🔓 Kickoff. Picks revealed.';
    $('lab1').textContent = 'THEIR ROW — REVEALED';
    ['t0','t1','t2'].forEach((id, i) => at(300 + i * 380, () => $(id).classList.add('flipped')));
    $('footline').innerHTML = 'Three drips… wait. <b>The tight end is a NUKE.</b>';
  });
  at(6400, () => $('nukemet').classList.add('blink'));
  // S3: live banking 8.2–14
  at(8200, () => {
    $('headline').textContent = 'Every card banks. Live.';
    $('footline').innerHTML = 'Points drip in <b>every minute their team has the ball.</b>';
    $('table').classList.add('golive');
    count($('by0'), 0, 9.8, 5400); count($('by1'), 0, 7.2, 5400); count($('by2'), 0, 6.4, 5400);
    count($('bt0'), 0, 8.9, 5400); count($('bt1'), 0, 10.3, 5400); count($('bt2'), 0, 1.2, 5400);
  });
  [['y0','+0.4'],['t1','+0.5'],['y1','+0.3'],['t0','+0.4'],['y2','+0.5'],['t1','+0.6'],['y0','+0.6'],['t0','+0.3']]
    .forEach((f, i) => at(8600 + i * 620, () => floater(f[0], f[1])));
  // S4: their nuke 14–18
  at(14000, () => $('playline').classList.add('on'));
  at(14700, () => {
    $('flashlayer').classList.add('go'); $('boom').classList.add('go'); $('stage').classList.add('quake');
    $('sy2').classList.add('on'); $('by2').style.opacity = '0';
    count($('by2'), 6.4, 0.0, 600); count($('bt2'), 1.2, 13.2, 600);
    $('headline').textContent = 'Their nuke hit first.';
    $('footline').innerHTML = 'Kittle: wiped to zero. <b>Blacked out ten minutes.</b>';
  });
  at(16600, () => { $('boom').classList.remove('go'); $('stage').classList.remove('quake'); $('playline').classList.remove('on'); });
  // S5: EMP response 18–24.5
  at(18000, () => {
    $('headline').textContent = 'You were holding a power-up.';
    $('footline').innerHTML = '';
    $('empcard').classList.add('go');
  });
  at(20400, () => {
    $('empcard').classList.remove('go'); $('empcard').classList.add('gone');
    $('iceflash').classList.add('go'); $('stage').classList.add('quake');
    ['ft0','ft1','ft2'].forEach((f) => $(f).classList.add('on'));
    $('headline').textContent = 'Their whole row: frozen.';
    $('footline').innerHTML = 'Their drips stop for 10 minutes. <b>Yours keep running.</b>';
    count($('by0'), 9.8, 15.1, 3600); count($('by1'), 7.2, 12.6, 3600);
  });
  [['y0','+0.7'],['y1','+0.5'],['y0','+0.6'],['y1','+0.8']].forEach((f, i) => at(20900 + i * 700, () => floater(f[0], f[1])));
  at(21000, () => $('stage').classList.remove('quake'));
  // S6 final 24.5, S7 end 27.5
  at(24500, () => $('s6').classList.add('on'));
  at(27500, () => { $('s6').classList.remove('on'); $('s7').classList.add('on'); });
};
</script>
</body>
</html>
