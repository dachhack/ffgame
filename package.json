{
  "name": "gridiron-clash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Drip League FF — a real-time fantasy football game. Web demo seeded with the PeakedInDynasty 2025 season.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "validate": "node scripts/espn/validate.mjs",
    "gen:rulebook": "tsx scripts/gen-rulebook.mjs",
    "check:prices": "tsx scripts/check-powerup-prices.mjs",
    "check:metrics": "tsx scripts/check-locked-metrics.mjs",
    "check:parity": "npm run check:prices && npm run check:metrics"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "posthog-js": "^1.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
